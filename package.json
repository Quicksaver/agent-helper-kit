{
  "name": "custom-vscode",
  "displayName": "Custom VS Code",
  "description": "Personal VS Code extension",
  "version": "0.0.2",
  "publisher": "Quicksaver",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "custom-vscode.helloWorld",
        "title": "Hello World",
        "category": "Custom"
      }
    ]
  },
  "packageManager": "yarn@4.11.0",
  "scripts": {
    "build": "node esbuild.mjs",
    "deploy": "yarn package:build && yarn package:install",
    "lint:check": "yarn lint:tsc && yarn lint:eslint && yarn lint:prettier",
    "lint:eslint": "eslint . --ext .js,.ts",
    "lint:fix": "yarn lint:tsc && yarn lint:eslint --fix && yarn lint:prettier --write",
    "lint:prettier": "prettier --log-level=warn --check .",
    "lint:tsc": "tsc --noEmit",
    "package:build": "vsce package --no-dependencies --allow-missing-repository --skip-license",
    "package:install": "code --install-extension $(ls -t *.vsix | head -1)",
    "test": "vitest run",
    "test:watch": "vitest",
    "vscode:prepublish": "yarn build",
    "watch": "node esbuild.mjs --watch"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.7.1",
    "@types/node": "^25.2.1",
    "@types/vscode": "^1.109.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-perfectionist": "^5.5.0",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  }
}
