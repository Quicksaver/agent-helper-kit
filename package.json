{
  "name": "custom-vscode",
  "displayName": "Custom VS Code",
  "description": "Personal VS Code extension",
  "version": "0.5.5",
  "publisher": "Quicksaver",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onLanguageModelTool:run_in_sync_terminal",
    "onLanguageModelTool:run_in_async_terminal",
    "onLanguageModelTool:await_terminal_enhanced",
    "onLanguageModelTool:get_terminal_output_enhanced",
    "onLanguageModelTool:kill_terminal_enhanced",
    "onLanguageModelTool:terminal_last_command_enhanced"
  ],
  "contributes": {
    "commands": [
      {
        "command": "custom-vscode.reviewCommentToChat",
        "title": "Copy to Chat",
        "category": "Custom",
        "enablement": "config.custom-vscode.bringToChat.enabled",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "custom-vscode.shellCommands.clearFinished",
        "title": "Clear",
        "category": "Shell Commands",
        "enablement": "config.custom-vscode.terminalTools.enabled",
        "icon": "$(clear-all)"
      },
      {
        "command": "custom-vscode.shellCommands.killEntry",
        "title": "Kill",
        "category": "Shell Commands",
        "enablement": "config.custom-vscode.terminalTools.enabled",
        "icon": "$(close)"
      },
      {
        "command": "custom-vscode.shellCommands.deleteEntry",
        "title": "Delete",
        "category": "Shell Commands",
        "enablement": "config.custom-vscode.terminalTools.enabled",
        "icon": "$(trash)"
      },
      {
        "command": "custom-vscode.shellCommands.openEntry",
        "title": "Show Output",
        "category": "Shell Commands",
        "enablement": "config.custom-vscode.terminalTools.enabled"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "custom-vscode.reviewCommentToChat",
          "when": "config.custom-vscode.bringToChat.enabled"
        }
      ],
      "comments/commentThread/title": [
        {
          "command": "custom-vscode.reviewCommentToChat",
          "group": "inline",
          "when": "config.custom-vscode.bringToChat.enabled"
        }
      ],
      "view/item/context": [
        {
          "command": "custom-vscode.shellCommands.killEntry",
          "group": "inline",
          "when": "view == custom-vscode.shellCommandsView && viewItem == running && config.custom-vscode.terminalTools.enabled"
        },
        {
          "command": "custom-vscode.shellCommands.deleteEntry",
          "group": "inline",
          "when": "view == custom-vscode.shellCommandsView && viewItem == finished && config.custom-vscode.terminalTools.enabled"
        }
      ],
      "view/title": [
        {
          "command": "custom-vscode.shellCommands.clearFinished",
          "group": "navigation",
          "when": "view == custom-vscode.shellCommandsView && config.custom-vscode.terminalTools.enabled"
        }
      ]
    },
    "viewsContainers": {
      "panel": [
        {
          "id": "custom-vscode-shellCommandsPanel",
          "title": "Shell Commands",
          "icon": "$(terminal)",
          "when": "config.custom-vscode.terminalTools.enabled"
        }
      ]
    },
    "views": {
      "custom-vscode-shellCommandsPanel": [
        {
          "id": "custom-vscode.shellCommandsView",
          "name": "Shell Commands",
          "icon": "$(terminal)",
          "when": "config.custom-vscode.terminalTools.enabled"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "custom-vscode.bringCommentsToChat",
        "name": "bringCommentsToChat",
        "fullName": "Code Review Comment",
        "description": "Copy code review comment content to chat, including file path and line number",
        "isSticky": false
      }
    ],
    "configuration": {
      "title": "Custom VS Code",
      "properties": {
        "custom-vscode.bringToChat.enabled": {
          "default": true,
          "description": "Enable the bring-to-chat feature (chat participant, command, and review comment button).",
          "type": "boolean"
        },
        "custom-vscode.terminalTools.enabled": {
          "default": true,
          "description": "Enable custom terminal language model tools.",
          "type": "boolean"
        },
        "custom-vscode.terminalOutput.memoryToFileSpillMinutes": {
          "default": 2,
          "description": "Minutes to keep terminal output in memory before spilling it to a temp file.",
          "minimum": 0,
          "type": "number"
        },
        "custom-vscode.terminalOutput.startupPurgeMaxAgeHours": {
          "default": 6,
          "description": "On extension host startup, purge persisted terminal output files older than this many hours.",
          "minimum": 0,
          "type": "number"
        }
      }
    },
    "languageModelTools": [
      {
        "name": "run_in_sync_terminal",
        "toolReferenceName": "runInSyncTerminal",
        "displayName": "Run In Sync Terminal",
        "when": "config.custom-vscode.terminalTools.enabled",
        "icon": "$(terminal)",
        "modelDescription": "Run a shell command synchronously. First run starts in workspace root (or home if no workspace); later runs reuse the last resolved PWD from previous sync commands. Returns an id and status metadata (exitCode, terminationSignal, timedOut); provide full_output, last_lines, or regex to include output in the response, or use id to await or retrieve output.",
        "canBeReferencedInPrompt": true,
        "inputSchema": {
          "type": "object",
          "required": [
            "command",
            "explanation",
            "goal",
            "timeout"
          ],
          "properties": {
            "command": {
              "type": "string",
              "description": "Shell command to execute."
            },
            "explanation": {
              "type": "string",
              "description": "One-sentence summary of the command."
            },
            "goal": {
              "type": "string",
              "description": "Short purpose of the command."
            },
            "full_output": {
              "type": "boolean",
              "description": "When true, include output from the beginning in this tool response."
            },
            "last_lines": {
              "type": "number",
              "description": "Optional trailing line count to include in this tool response; mutually exclusive with regex.",
              "minimum": 0
            },
            "regex": {
              "type": "string",
              "description": "Optional regex filter for lines included in this tool response; mutually exclusive with last_lines."
            },
            "timeout": {
              "type": "number",
              "description": "Timeout in ms; use 0 for no timeout."
            }
          },
          "allOf": [
            {
              "not": {
                "required": [
                  "last_lines",
                  "regex"
                ]
              }
            },
            {
              "not": {
                "required": [
                  "full_output",
                  "last_lines"
                ]
              }
            },
            {
              "not": {
                "required": [
                  "full_output",
                  "regex"
                ]
              }
            }
          ]
        }
      },
      {
        "name": "run_in_async_terminal",
        "toolReferenceName": "runInAsyncTerminal",
        "displayName": "Run In Async Terminal",
        "when": "config.custom-vscode.terminalTools.enabled",
        "icon": "$(terminal)",
        "modelDescription": "Run a shell command asynchronously. Each call runs in workspace root (or home if no workspace). Returns a terminal id to await or retrieve output.",
        "canBeReferencedInPrompt": true,
        "inputSchema": {
          "type": "object",
          "required": [
            "command",
            "explanation",
            "goal",
            "timeout"
          ],
          "properties": {
            "command": {
              "type": "string",
              "description": "Shell command to execute."
            },
            "explanation": {
              "type": "string",
              "description": "One-sentence summary of the command."
            },
            "goal": {
              "type": "string",
              "description": "Short purpose of the command."
            },
            "timeout": {
              "type": "number",
              "description": "Timeout in ms; use 0 for no timeout."
            }
          }
        }
      },
      {
        "name": "await_terminal_enhanced",
        "toolReferenceName": "awaitTerminalEnhanced",
        "displayName": "Await Terminal",
        "when": "config.custom-vscode.terminalTools.enabled",
        "icon": "$(clock)",
        "modelDescription": "Wait for a terminal command to finish for an id from run_in_async_terminal or run_in_sync_terminal, then return output and status (exitCode, terminationSignal, timedOut); sync ids return immediately.",
        "canBeReferencedInPrompt": true,
        "inputSchema": {
          "type": "object",
          "required": [
            "id",
            "timeout"
          ],
          "properties": {
            "id": {
              "type": "string",
              "description": "Terminal id from run_in_sync_terminal or run_in_async_terminal."
            },
            "timeout": {
              "type": "number",
              "description": "Timeout in ms; use 0 for no timeout."
            }
          }
        }
      },
      {
        "name": "get_terminal_output_enhanced",
        "toolReferenceName": "getTerminalOutputEnhanced",
        "displayName": "Get Terminal Output",
        "when": "config.custom-vscode.terminalTools.enabled",
        "icon": "$(output)",
        "modelDescription": "Read output and status (isRunning, exitCode, terminationSignal) for a terminal id from run_in_sync_terminal or run_in_async_terminal (returns only new output since last read by default).",
        "canBeReferencedInPrompt": true,
        "inputSchema": {
          "type": "object",
          "required": [
            "id"
          ],
          "properties": {
            "id": {
              "type": "string",
              "description": "Terminal id from run_in_sync_terminal or run_in_async_terminal."
            },
            "full_output": {
              "type": "boolean",
              "description": "When true, return output from the beginning."
            },
            "last_lines": {
              "type": "number",
              "description": "Optional trailing line count to return; mutually exclusive with regex.",
              "minimum": 0
            },
            "regex": {
              "type": "string",
              "description": "Optional regex filter for matching lines; mutually exclusive with last_lines."
            }
          },
          "allOf": [
            {
              "not": {
                "required": [
                  "last_lines",
                  "regex"
                ]
              }
            }
          ]
        }
      },
      {
        "name": "kill_terminal_enhanced",
        "toolReferenceName": "killTerminalEnhanced",
        "displayName": "Kill Terminal",
        "when": "config.custom-vscode.terminalTools.enabled",
        "icon": "$(close)",
        "modelDescription": "Stop a running background terminal command.",
        "canBeReferencedInPrompt": true,
        "inputSchema": {
          "type": "object",
          "required": [
            "id"
          ],
          "properties": {
            "id": {
              "type": "string",
              "description": "Terminal id from run_in_sync_terminal or run_in_async_terminal."
            }
          }
        }
      },
      {
        "name": "terminal_last_command_enhanced",
        "toolReferenceName": "terminalLastCommandEnhanced",
        "displayName": "Terminal Last Command",
        "when": "config.custom-vscode.terminalTools.enabled",
        "icon": "$(history)",
        "modelDescription": "Get the last command executed via run_in_sync_terminal or run_in_async_terminal.",
        "canBeReferencedInPrompt": true,
        "inputSchema": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "description": "Optional terminal id from run_in_sync_terminal or run_in_async_terminal to scope the lookup."
            }
          }
        }
      }
    ]
  },
  "packageManager": "yarn@4.12.0",
  "scripts": {
    "build": "node esbuild.mjs",
    "lint:check": "yarn lint:tsc && yarn lint:eslint --max-warnings 0 && yarn lint:prettier",
    "lint:eslint": "eslint . --ext .js,.ts",
    "lint:fix": "yarn lint:tsc && yarn lint:eslint --fix && yarn lint:prettier --write",
    "lint:prettier": "prettier --log-level=warn --check .",
    "lint:tsc": "tsc --noEmit",
    "package": "yarn package:build && yarn package:install",
    "package:build": "vsce package --no-dependencies --allow-missing-repository --skip-license",
    "package:install": "code --install-extension $(ls -t *.vsix | head -1)",
    "test": "vitest run",
    "test:watch": "vitest",
    "vscode:prepublish": "yarn lint:check && yarn build",
    "watch": "node esbuild.mjs --watch"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.9.0",
    "@types/node": "^25.3.3",
    "@types/vscode": "^1.109.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-perfectionist": "^5.6.0",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
