{
  "name": "custom-vscode",
  "displayName": "Custom VS Code",
  "description": "Personal VS Code extension",
  "version": "0.3.9",
  "publisher": "Quicksaver",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onLanguageModelTool:run_in_terminal_enhanced",
    "onLanguageModelTool:await_terminal_enhanced",
    "onLanguageModelTool:get_terminal_output_enhanced",
    "onLanguageModelTool:kill_terminal_enhanced",
    "onLanguageModelTool:terminal_last_command_enhanced"
  ],
  "contributes": {
    "commands": [
      {
        "command": "custom-vscode.reviewCommentToChat",
        "title": "Copy to Chat",
        "category": "Custom",
        "icon": "$(comment-discussion)"
      }
    ],
    "menus": {
      "comments/commentThread/title": [
        {
          "command": "custom-vscode.reviewCommentToChat",
          "group": "inline"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "custom-vscode.bringCommentsToChat",
        "name": "bringCommentsToChat",
        "fullName": "Code Review Comment",
        "description": "Copy code review comment content to chat, including file path and line number",
        "isSticky": false
      }
    ],
    "languageModelTools": [
      {
        "name": "run_in_terminal_enhanced",
        "toolReferenceName": "runInTerminalEnhanced",
        "displayName": "Run In Terminal",
        "icon": "$(terminal)",
        "modelDescription": "Run a shell command in a persistent bash session. Foreground returns output and status (exitCode, terminationSignal, timedOut); background returns a terminal id.",
        "canBeReferencedInPrompt": true,
        "inputSchema": {
          "type": "object",
          "required": [
            "command",
            "explanation",
            "goal",
            "isBackground",
            "timeout"
          ],
          "properties": {
            "command": {
              "type": "string",
              "description": "Shell command to execute."
            },
            "explanation": {
              "type": "string",
              "description": "One-sentence summary of the command."
            },
            "goal": {
              "type": "string",
              "description": "Short purpose of the command."
            },
            "isBackground": {
              "type": "boolean",
              "description": "Run asynchronously in the background."
            },
            "timeout": {
              "type": "number",
              "description": "Timeout in ms; use 0 for no timeout."
            }
          }
        }
      },
      {
        "name": "await_terminal_enhanced",
        "toolReferenceName": "awaitTerminalEnhanced",
        "displayName": "Await Terminal",
        "icon": "$(clock)",
        "modelDescription": "Wait for a background terminal command to finish and return output and status (exitCode, terminationSignal, timedOut).",
        "canBeReferencedInPrompt": true,
        "inputSchema": {
          "type": "object",
          "required": [
            "id",
            "timeout"
          ],
          "properties": {
            "id": {
              "type": "string",
              "description": "Background terminal id from run_in_terminal_enhanced."
            },
            "timeout": {
              "type": "number",
              "description": "Timeout in ms; use 0 for no timeout."
            }
          }
        }
      },
      {
        "name": "get_terminal_output_enhanced",
        "toolReferenceName": "getTerminalOutputEnhanced",
        "displayName": "Get Terminal Output",
        "icon": "$(output)",
        "modelDescription": "Read output from a background terminal command (only new since last read by default) and status (isRunning, exitCode, terminationSignal, timedOut).",
        "canBeReferencedInPrompt": true,
        "inputSchema": {
          "type": "object",
          "required": [
            "id"
          ],
          "properties": {
            "id": {
              "type": "string",
              "description": "Background terminal id from run_in_terminal_enhanced."
            },
            "full_output": {
              "type": "boolean",
              "description": "When true, return output from the beginning."
            },
            "last_lines": {
              "type": "number",
              "description": "Optional trailing line count to return; mutually exclusive with regex.",
              "minimum": 0
            },
            "regex": {
              "type": "string",
              "description": "Optional regex filter for matching lines; mutually exclusive with last_lines."
            }
          },
          "allOf": [
            {
              "not": {
                "required": [
                  "last_lines",
                  "regex"
                ]
              }
            }
          ]
        }
      },
      {
        "name": "kill_terminal_enhanced",
        "toolReferenceName": "killTerminalEnhanced",
        "displayName": "Kill Terminal",
        "icon": "$(close)",
        "modelDescription": "Stop a running background terminal command.",
        "canBeReferencedInPrompt": true,
        "inputSchema": {
          "type": "object",
          "required": [
            "id"
          ],
          "properties": {
            "id": {
              "type": "string",
              "description": "Background terminal id from run_in_terminal_enhanced."
            }
          }
        }
      },
      {
        "name": "terminal_last_command_enhanced",
        "toolReferenceName": "terminalLastCommandEnhanced",
        "displayName": "Terminal Last Command",
        "icon": "$(history)",
        "modelDescription": "Get the last command executed via run_in_terminal_enhanced.",
        "canBeReferencedInPrompt": true,
        "inputSchema": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "description": "Optional background terminal id to scope the lookup."
            }
          }
        }
      }
    ]
  },
  "packageManager": "yarn@4.12.0",
  "scripts": {
    "build": "node esbuild.mjs",
    "lint:check": "yarn lint:tsc && yarn lint:eslint --max-warnings 0 && yarn lint:prettier",
    "lint:eslint": "eslint . --ext .js,.ts",
    "lint:fix": "yarn lint:tsc && yarn lint:eslint --fix && yarn lint:prettier --write",
    "lint:prettier": "prettier --log-level=warn --check .",
    "lint:tsc": "tsc --noEmit",
    "package": "yarn package:build && yarn package:install",
    "package:build": "vsce package --no-dependencies --allow-missing-repository --skip-license",
    "package:install": "code --install-extension $(ls -t *.vsix | head -1)",
    "test": "vitest run",
    "test:watch": "vitest",
    "vscode:prepublish": "yarn lint:check && yarn build",
    "watch": "node esbuild.mjs --watch"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.9.0",
    "@types/node": "^25.3.3",
    "@types/vscode": "^1.109.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-perfectionist": "^5.6.0",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
