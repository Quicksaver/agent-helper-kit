{
  "name": "custom-vscode",
  "displayName": "Custom VS Code",
  "description": "Personal VS Code extension",
  "version": "0.3.5",
  "publisher": "Quicksaver",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onMcpServerDefinitionProvider:custom-vscode.terminal-tools-mcp",
    "onLanguageModelTool:custom_run_in_terminal",
    "onLanguageModelTool:custom_await_terminal",
    "onLanguageModelTool:custom_get_terminal_output",
    "onLanguageModelTool:custom_kill_terminal",
    "onLanguageModelTool:custom_terminal_last_command"
  ],
  "contributes": {
    "commands": [
      {
        "command": "custom-vscode.reviewCommentToChat",
        "title": "Copy to Chat",
        "category": "Custom",
        "icon": "$(comment-discussion)"
      }
    ],
    "menus": {
      "comments/commentThread/title": [
        {
          "command": "custom-vscode.reviewCommentToChat",
          "group": "inline"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "custom-vscode.bringCommentsToChat",
        "name": "bringCommentsToChat",
        "fullName": "Code Review Comment",
        "description": "Copy code review comment content to chat, including file path and line number",
        "isSticky": false
      }
    ],
    "mcpServerDefinitionProviders": [
      {
        "id": "custom-vscode.terminal-tools-mcp",
        "label": "Custom Terminal Tools MCP"
      }
    ],
    "languageModelTools": [
      {
        "name": "custom_run_in_terminal",
        "displayName": "Custom Run In Terminal",
        "modelDescription": "Execute shell commands in a persistent bash terminal session. Supports foreground and background execution with output capture.",
        "canBeReferencedInPrompt": true,
        "inputSchema": {
          "type": "object",
          "required": [
            "command",
            "explanation",
            "goal",
            "isBackground",
            "timeout"
          ],
          "properties": {
            "command": {
              "type": "string",
              "description": "The command to run in the terminal."
            },
            "explanation": {
              "type": "string",
              "description": "A one-sentence description of what the command does."
            },
            "goal": {
              "type": "string",
              "description": "A short description of the purpose of the command."
            },
            "isBackground": {
              "type": "boolean",
              "description": "Whether the command runs as a background process."
            },
            "timeout": {
              "type": "number",
              "description": "Timeout in milliseconds. Use 0 for no timeout."
            }
          }
        }
      },
      {
        "name": "custom_await_terminal",
        "displayName": "Custom Await Terminal",
        "modelDescription": "Wait for a background terminal process to complete and return its output and status.",
        "canBeReferencedInPrompt": true,
        "inputSchema": {
          "type": "object",
          "required": [
            "id",
            "timeout"
          ],
          "properties": {
            "id": {
              "type": "string",
              "description": "Background terminal identifier returned by custom_run_in_terminal."
            },
            "timeout": {
              "type": "number",
              "description": "Timeout in milliseconds. Use 0 for no timeout."
            }
          }
        }
      },
      {
        "name": "custom_get_terminal_output",
        "displayName": "Custom Get Terminal Output",
        "modelDescription": "Read current output from a background terminal process.",
        "canBeReferencedInPrompt": true,
        "inputSchema": {
          "type": "object",
          "required": [
            "id"
          ],
          "properties": {
            "id": {
              "type": "string",
              "description": "Background terminal identifier returned by custom_run_in_terminal."
            },
            "last_lines": {
              "type": "number",
              "description": "Optional number of trailing lines to return. Mutually exclusive with regex.",
              "minimum": 0
            },
            "regex": {
              "type": "string",
              "description": "Optional regex filter expression to return only matching lines. Mutually exclusive with last_lines."
            }
          },
          "allOf": [
            {
              "not": {
                "required": [
                  "last_lines",
                  "regex"
                ]
              }
            }
          ]
        }
      },
      {
        "name": "custom_kill_terminal",
        "displayName": "Custom Kill Terminal",
        "modelDescription": "Terminate a running background terminal process.",
        "canBeReferencedInPrompt": true,
        "inputSchema": {
          "type": "object",
          "required": [
            "id"
          ],
          "properties": {
            "id": {
              "type": "string",
              "description": "Background terminal identifier returned by custom_run_in_terminal."
            }
          }
        }
      },
      {
        "name": "custom_terminal_last_command",
        "displayName": "Custom Terminal Last Command",
        "modelDescription": "Return the last command executed via custom_run_in_terminal.",
        "canBeReferencedInPrompt": true,
        "inputSchema": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "description": "Optional background terminal identifier to get the last command for a specific terminal."
            }
          }
        }
      }
    ]
  },
  "packageManager": "yarn@4.12.0",
  "scripts": {
    "build": "node esbuild.mjs",
    "lint:check": "yarn lint:tsc && yarn lint:eslint --max-warnings 0 && yarn lint:prettier",
    "lint:eslint": "eslint . --ext .js,.ts",
    "lint:fix": "yarn lint:tsc && yarn lint:eslint --fix && yarn lint:prettier --write",
    "lint:prettier": "prettier --log-level=warn --check .",
    "lint:tsc": "tsc --noEmit",
    "package": "yarn package:build && yarn package:install",
    "package:build": "vsce package --no-dependencies --allow-missing-repository --skip-license",
    "package:install": "code --install-extension $(ls -t *.vsix | head -1)",
    "test": "vitest run",
    "test:watch": "vitest",
    "vscode:prepublish": "yarn lint:check && yarn build",
    "watch": "node esbuild.mjs --watch"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.9.0",
    "@types/node": "^25.3.3",
    "@types/vscode": "^1.109.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-perfectionist": "^5.6.0",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  }
}
