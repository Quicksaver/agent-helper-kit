{
  "compilerOptions": {
    "baseUrl": "./",
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "lib": ["ES2023"],
    "module": "node20",
    "moduleResolution": "nodenext",
    "noEmit": true,
    "outDir": "./dist",
    "paths": {
      "@/*": ["src/*"]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "ES2023"
  },
  "exclude": ["node_modules", "dist"],
  "include": ["**/*.ts"]
}
