{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "lib": ["ESNext"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmit": true,
    "outDir": "./dist",
    "paths": {
      "@/*": ["./src/*"]
    },
    "resolveJsonModule": true,
    "rootDir": "./",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "types": []
  },
  "exclude": ["node_modules", "dist"],
  "include": ["**/*.ts"]
}
